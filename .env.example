# ─────────────────────────────────────────────────
#  GARUDA POD — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to git.
# ─────────────────────────────────────────────────

# ── Society Settings ──────────────────────────────
SOCIETY_NAME="PFS Society"
SPEED_LIMIT_KMH=20
# Hard ceiling — any computed speed above this is logged as a camera/calibration
# anomaly and NOT sent as an alert (catches handheld-camera jitter, bad line
# calibration, tracking glitches, etc. instead of alerting on e.g. "263 km/h").
MAX_SPEED_KMH=80

# ── Camera 01 ─────────────────────────────────────
# For live CCTV: rtsp://user:password@192.168.1.100:554/channel/1
# For file test: /data/test.mp4  (mount your video file into the container)
CAM_01_RTSP_URL=rtsp://admin:admin@192.168.1.100:554/channel/1
CAM_01_CALIBRATION_METRES=8.0
# Y-position of virtual speed-trap lines as a fraction of frame height (0.0=top, 1.0=bottom)
CAM_01_LINE_A_Y_RATIO=0.35
CAM_01_LINE_B_Y_RATIO=0.65

# ── Camera 02 (uncomment when adding a second camera) ──
# CAM_02_RTSP_URL=rtsp://admin:admin@192.168.1.101:554/channel/1
# CAM_02_CALIBRATION_METRES=10.0
# CAM_02_LINE_A_Y_RATIO=0.30
# CAM_02_LINE_B_Y_RATIO=0.70

# ── WhatsApp — choose one provider ────────────────
# "twilio" or "meta"
WHATSAPP_PROVIDER=twilio

# Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta WhatsApp Cloud API (https://developers.facebook.com/apps)
META_PHONE_NUMBER_ID=your_phone_number_id
META_WHATSAPP_TOKEN=your_system_user_token

# Guard's WhatsApp number (with country code)
GUARD_WHATSAPP_TO=whatsapp:+919876543210

# ── Alert Settings ─────────────────────────────────
# Seconds to suppress duplicate alerts for the same plate
DEDUP_WINDOW_SECONDS=60
# Save a short video clip of each violation? (true/false)
SAVE_INCIDENT_CLIP=true
